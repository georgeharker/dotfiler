#!/bin/zsh
# Dotfiler - Main wrapper script for dotfile management system

# Capture script name early before functions change context
script_name="${${(%):-%x}:A}"
helper_script_dir="${script_name:h}"

source "${helper_script_dir}/helpers.zsh"

set -e

# Get the directory where this script is located
script_dir=$(find_dotfiles_script_directory)

function usage() {
    cat <<EOF
Dotfiler - Dotfile Management System

Usage: $script_name <command> [options]

Commands:
    gui                 Launch the graphical user interface
    setup               Run dotfile setup/installation
    check-updates       Check for updates to dotfiles
    update              Update dotfiles from repository
    update-self         Update dotfiler scripts themselves
    install             Run modular installation system (all modules)
    install-module      Run specific installation module

  Git wrappers (transparent — each prints the underlying git command):
    ingest <file>...    Move homedir file(s) into repo and symlink back
    add [<path>...]     Stage files in the dotfiles repo (git add)
    commit [options]    Commit staged changes (git commit)
    status [--fetch]    Show working tree, ahead, and behind state
    push [options]      Push commits to remote (git push)

Options:
    -h, --help         Show this help message

Examples:
    $script_name gui                      # Launch GUI
    $script_name setup -u                 # Run setup with unpack
    $script_name setup --bootstrap-hook /path/to/zdot/core/dotfiler-hook.zsh
                                          # Bootstrap: install hook symlink into repo
    $script_name setup --bootstrap        # Bootstrap then unpack all (fresh machine)
    $script_name check-updates --force    # Force update check
    $script_name update --quiet           # Update quietly
    $script_name update-self              # Update dotfiler scripts
    $script_name install                  # Run all installation modules
    $script_name install-module development-tools  # Run specific module
    $script_name ingest ~/.zshrc          # Adopt file into dotfiles repo
    $script_name add .zshrc              # Stage a change
    $script_name commit -m "Update zshrc" # Commit staged changes
    $script_name status --fetch           # Full status with network check
    $script_name push                     # Push to remote

For command-specific help, run:
    $script_name <command> --help
EOF
}

# Parse global options
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            exit 0
            ;;
        gui|setup|check-updates|update|update-self|install|install-module|ingest|add|commit|status|push)
            command="$1"
            shift
            break
            ;;
        *)
            echo "Error: Unknown option '$1'" >&2
            echo "Use '$0 --help' for usage information." >&2
            exit 1
            ;;
    esac
done

# Check if command was provided
if [[ -z "${command:-}" ]]; then
    echo "Error: No command specified" >&2
    usage
    exit 1
fi

# Execute the appropriate command
case "$command" in
    gui)
        # Get directories using helper functions
        dotfiles_dir=$(find_dotfiles_directory)
        setup_script="$script_dir/setup.zsh"
        
        # Launch the GUI with discovered directories and user arguments
        exec "$script_dir/dotfiler-gui" --dotfiles-dir "$dotfiles_dir" --setup-script "$setup_script" "$@"
        ;;
    setup)
        # Run setup script with all remaining arguments
        exec "$script_dir/setup.zsh" "$@"
        ;;
    check-updates)
        # Run check_update script with all remaining arguments
        exec "$script_dir/check_update.zsh" "$@"
        ;;
    update)
        # update.zsh handles both dotfiler script self-update and dotfiles
        # update in a single phased run.
        exec "$script_dir/update.zsh" "$@"
        ;;
    update-self)
        # Update dotfiler scripts only.
        exec "$script_dir/update.zsh" --update-phases=dotfiler "$@"
        ;;
   install)
       # Run install script with all remaining arguments
       exec "$script_dir/install.zsh" "$@"
       ;;
   install-module)
       # Run install_module script with all remaining arguments
       exec "$script_dir/install_module.zsh" "$@"
       ;;
   ingest|add|commit|status|push)
       # Transparent git wrappers — each prints the underlying git command.
       exec "$script_dir/git_commands.zsh" "$command" "$@"
       ;;
    *)
        echo "Error: Unknown command '$command'" >&2
        usage
        exit 1
        ;;
esac
